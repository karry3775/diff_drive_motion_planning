Panels:
  - Class: rviz_common/Displays
    Name: Displays
Visualization Manager:
  Class: ""
  Displays:
    - Class: rviz_default_plugins/Grid
      Name: Grid
      Enabled: true
      Plane Cell Count: 20

    - Class: rviz_default_plugins/TF
      Name: TF
      Enabled: true

    - Class: rviz_default_plugins/RobotModel
      Name: RobotModel
      Enabled: true
      Description Topic:
        Value: /robot_description

    - Class: rviz_default_plugins/Path
      Name: Raw Waypoints
      Enabled: true
      Topic:
        Value: /raw_waypoints
      Color: 255; 0; 0
      Line Style: Lines
      Line Width: 0.03

    - Class: rviz_default_plugins/Path
      Name: Smoothed Path
      Enabled: true
      Topic:
        Value: /smoothed_path
      Color: 0; 100; 255
      Line Style: Lines
      Line Width: 0.02

    - Class: rviz_default_plugins/Path
      Name: Trajectory
      Enabled: true
      Topic:
        Value: /trajectory
      Color: 0; 200; 255
      Line Style: Lines
      Line Width: 0.01

    - Class: rviz_default_plugins/Path
      Name: Robot Trail
      Enabled: true
      Topic:
        Value: /robot_trail
      Color: 0; 255; 0
      Line Style: Lines
      Line Width: 0.02

    - Class: rviz_default_plugins/Odometry
      Name: Odometry
      Enabled: true
      Topic:
        Value: /odom
      Keep: 1
      Shape:
        Value: Arrow

    - Class: rviz_default_plugins/MarkerArray
      Name: Obstacles
      Enabled: true
      Topic:
        Value: /obstacles

  Global Options:
    Fixed Frame: odom
    Frame Rate: 30

  Tools:
    - Class: rviz_default_plugins/MoveCamera
    - Class: rviz_default_plugins/FocusCamera

  Views:
    Current:
      Class: rviz_default_plugins/TopDownOrtho
      Name: TopDown
      Scale: 50
      X: 3.5
      Y: 1.0